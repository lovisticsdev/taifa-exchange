TAIFA_EXCHANGE_SERVICE_NAME=taifa-exchange
TAIFA_EXCHANGE_ENV=local

TAIFA_EXCHANGE_HTTP_ADDR=:8081
TAIFA_EXCHANGE_HTTP_READ_TIMEOUT=5s
TAIFA_EXCHANGE_HTTP_WRITE_TIMEOUT=10s
TAIFA_EXCHANGE_HTTP_IDLE_TIMEOUT=60s
TAIFA_EXCHANGE_HTTP_SHUTDOWN_TIMEOUT=10s

TAIFA_EXCHANGE_DATABASE_DSN=host=localhost port=5432 user=taifa password=taifa_dev_password dbname=taifa_exchange sslmode=disable
TAIFA_EXCHANGE_DATABASE_MIN_CONNS=1
TAIFA_EXCHANGE_DATABASE_MAX_CONNS=5
TAIFA_EXCHANGE_DATABASE_CONNECT_TIMEOUT=15s

TAIFA_EXCHANGE_TAIFA_ID_BASE_URL=http://localhost:8080
TAIFA_EXCHANGE_TAIFA_ID_TIMEOUT=10s

TAIFA_EXCHANGE_SEED_TIMEOUT=5m

TAIFA_EXCHANGE_TEST_BASE_URL=http://localhost:8081
TAIFA_EXCHANGE_TEST_TAIFA_ID_BASE_URL=http://localhost:8080
TAIFA_EXCHANGE_TEST_USERNAME=clinician.seed
TAIFA_EXCHANGE_TEST_PASSWORD=ExampleDevPass123!
TAIFA_EXCHANGE_TEST_ORGANIZATION_ID=ORG-HP-CLINIC